    "expo-intent-launcher": "~10.11.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.73.2",
    "react-native-web": "~0.19.6",
    "@react-native-async-storage/async-storage": "1.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.12.9",
    "@babel/plugin-proposal-private-methods": "^7.18.6",
    "@types/react": "~18.2.45",
    "typescript": "^5.3.0"
  },
  "private": true,
